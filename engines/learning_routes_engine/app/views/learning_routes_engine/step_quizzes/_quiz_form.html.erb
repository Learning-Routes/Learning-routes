<div id="step_quiz_form" data-controller="step-quiz" data-step-quiz-total-value="<%= questions.size %>">
  <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.75rem; padding:1.5rem;">
    <%# Header %>
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
      <div style="display:flex; align-items:center; gap:0.75rem;">
        <div style="display:inline-flex; align-items:center; justify-content:center; width:2.5rem; height:2.5rem; border-radius:0.75rem; background:var(--color-warning-bg); border:1px solid var(--color-warning-border);">
          <svg aria-hidden="true" style="width:1.25rem; height:1.25rem; color:var(--color-warning);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <h3 style="font-size:0.875rem; font-weight:600; color:var(--color-txt); margin:0;"><%= t("learning_engine.step_quiz.title") %></h3>
          <p style="font-size:0.75rem; color:var(--color-sub); margin:0;"><%= t("learning_engine.step_quiz.subtitle", count: questions.size) %></p>
        </div>
      </div>
      <span style="font-size:0.75rem; color:var(--color-muted); font-family:'DM Mono',monospace;" data-step-quiz-target="counter">
        0/<%= questions.size %>
      </span>
    </div>

    <%# Questions %>
    <%= form_with url: learning_routes_engine.submit_route_step_step_quiz_path(route, step),
                  method: :post, data: { step_quiz_target: "form" } do |f| %>
      <div class="space-y-5">
        <% questions.each_with_index do |question, idx| %>
          <div style="border-radius:0.5rem; background:var(--color-tint-strong); border:1px solid var(--color-tint); padding:1rem;">
            <p style="font-size:0.875rem; font-weight:500; color:var(--color-txt); margin:0 0 0.75rem;">
              <span style="color:var(--color-muted); font-family:'DM Mono',monospace; font-size:0.75rem; margin-right:0.5rem;"><%= idx + 1 %>.</span>
              <%= question.body %>
            </p>
            <div class="space-y-2">
              <% Array(question.options).each do |option| %>
                <label style="display:flex; align-items:center; gap:0.75rem; padding:0.625rem; border-radius:0.5rem; cursor:pointer; transition:background 0.2s;">
                  <input type="radio"
                         name="answers[<%= question.id %>]"
                         value="<%= option %>"
                         class="w-4 h-4 text-indigo-500 accent-indigo-500"
                         data-action="change->step-quiz#markAnswered">
                  <span style="font-size:0.875rem; color:var(--color-sub); transition:color 0.2s;"><%= option %></span>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div style="margin-top:1.5rem; display:flex; align-items:center; justify-content:space-between;">
        <p style="font-size:0.75rem; color:var(--color-muted); margin:0;"><%= t("learning_engine.step_quiz.passing_note") %></p>
        <button type="submit"
                style="border-radius:0.5rem; padding:0.5rem 1.25rem; font-size:0.875rem; font-weight:600; color:#fff; border:none; cursor:pointer; background:linear-gradient(to right, #6366f1, #a855f7); transition:opacity 0.2s;"
                data-step-quiz-target="submitBtn"
                disabled>
          <%= t("learning_engine.step_quiz.submit") %>
        </button>
      </div>
    <% end %>
  </div>
</div>
