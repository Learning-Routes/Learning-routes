<%
  next_step = @route.route_steps
    .where("position > ?", @step.position)
    .where(status: [:available])
    .order(:position).first
  tracker = LearningRoutesEngine::RouteProgressTracker.new(@route)
  progress = tracker.progress_summary
  engagement = current_user.user_engagement
  route_completed = @route.completed?
  xp_amount = XpService::XP_VALUES[:step_complete]
  leveled_up = @xp_result&.dig(:leveled_up) || false
  new_level = @xp_result&.dig(:level) || engagement&.current_level || 1
%>

<%= turbo_stream.replace "step_complete_btn" do %>
  <div id="step_complete_btn" class="flex items-center gap-2 text-green-400 text-sm font-medium">
    <svg aria-hidden="true" class="w-5 h-5 celebration-pulse" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
    <%= t("step_complete.completed") %>
  </div>
<% end %>

<%= turbo_stream.replace "route_progress_bar" do %>
  <div id="route_progress_bar"
       style="height:100%; background:linear-gradient(to right, #6366f1, #a855f7); transition:width 0.7s ease; width:<%= progress[:percentage] %>%;"></div>
<% end %>

<% if engagement %>
  <%= turbo_stream.replace "engagement_stats" do %>
    <div id="engagement_stats"
         data-controller="engagement"
         data-engagement-xp-value="<%= engagement.total_xp %>"
         data-engagement-level-value="<%= engagement.current_level %>"
         data-engagement-streak-value="<%= engagement.current_streak %>"
         data-engagement-progress-value="<%= engagement.level_progress_percentage %>"
         data-engagement-xp-gained-value="<%= xp_amount %>"
         data-engagement-leveled-up-value="<%= leveled_up %>"
         class="hidden md:flex">
      <%= render "shared/engagement_bar", engagement: engagement %>
    </div>
  <% end %>
<% end %>

<%# === Celebration === %>
<% if leveled_up %>
  <%# Level up = epic celebration %>
  <%= turbo_stream.append "celebrations" do %>
    <%= render "shared/celebration", tier: "epic", xp: xp_amount,
        message: t("celebration.level_up", level: new_level), level: new_level, streak: 0 %>
  <% end %>
<% elsif route_completed %>
  <%# Route complete = epic celebration %>
  <%= turbo_stream.append "celebrations" do %>
    <%= render "shared/celebration", tier: "epic", xp: xp_amount + XpService::XP_VALUES[:route_complete],
        message: t("celebration.route_complete"), level: 0, streak: engagement&.current_streak || 0 %>
  <% end %>
<% else %>
  <%# Normal step complete = big celebration %>
  <%= turbo_stream.append "celebrations" do %>
    <%= render "shared/celebration", tier: "big", xp: xp_amount,
        message: t("celebration.step_complete"), level: 0, streak: 0 %>
  <% end %>
<% end %>

<% if next_step %>
  <%= turbo_stream.append "step_navigation" do %>
    <div class="mt-6 text-center">
      <%= link_to t("step_complete.continue_next"), learning_routes_engine.route_step_path(@route, next_step),
          class: "inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-semibold text-white bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-400 hover:to-purple-400 transition" %>
    </div>
  <% end %>
<% end %>
