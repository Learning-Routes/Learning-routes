<div class="space-y-6">
  <div>
    <span style="display:inline-flex; align-items:center; border-radius:9999px; padding:0.125rem 0.625rem; font-size:0.75rem; font-weight:500; background:var(--color-badge-exercise-bg); color:var(--color-badge-exercise-text); margin-bottom:0.5rem;">
      <%= t('learning_engine.exercise.badge') %>
    </span>
    <h1 style="font-size:1.5rem; font-weight:700; color:var(--color-txt); margin:0;"><%= @step.localized_title %></h1>
    <p style="font-size:0.875rem; color:var(--color-sub); margin:0.25rem 0 0;"><%= @step.localized_description %></p>
  </div>

  <% if @content_generating %>
    <%= render "loading_skeleton" %>
  <% elsif @content %>
    <!-- Exercise instructions -->
    <div class="lesson-content" data-controller="math-renderer" data-math-renderer-target="content">
      <%= @rendered_html %>
    </div>

    <!-- Code editor -->
    <div data-controller="code-editor"
         data-code-editor-language-value="<%= @step.metadata&.dig('language') || 'javascript' %>"
         data-code-editor-step-id-value="<%= @step.id %>">
      <div class="code-block">
        <div style="display:flex; align-items:center; justify-content:space-between; padding:0.5rem 1rem; border-bottom:1px solid var(--color-border-subtle);">
          <span style="font-size:0.75rem; color:var(--color-muted); font-family:'DM Mono',monospace;"><%= @step.metadata&.dig('language') || 'javascript' %></span>
          <div style="display:flex; gap:0.5rem;">
            <button data-action="click->code-editor#reset" style="font-size:0.75rem; color:var(--color-muted); background:none; border:none; cursor:pointer;"><%= t('learning_engine.exercise.reset') %></button>
          </div>
        </div>
        <div data-code-editor-target="editorContainer" class="min-h-[300px]"></div>
      </div>

      <div style="display:flex; gap:0.75rem; margin-top:1rem;">
        <button data-action="click->code-editor#submit"
                style="border-radius:0.5rem; padding:0.5rem 1rem; font-size:0.875rem; font-weight:600; color:#fff; border:none; cursor:pointer; background:linear-gradient(to right, #6366f1, #a855f7); transition:opacity 0.2s;">
          <%= t('learning_engine.exercise.submit') %>
        </button>
        <button data-action="click->code-editor#requestHint"
                style="border-radius:0.5rem; padding:0.5rem 1rem; font-size:0.875rem; font-weight:500; color:var(--color-sub); background:var(--color-tint-strong); border:1px solid var(--color-border-subtle); cursor:pointer; transition:all 0.2s;">
          <%= t('learning_engine.exercise.hint') %>
        </button>
      </div>

      <!-- Hint area -->
      <div id="exercise_hint_<%= @step.id %>" class="mt-4"></div>

      <!-- Feedback area -->
      <div id="exercise_feedback_<%= @step.id %>" data-code-editor-target="output" class="mt-4"></div>
    </div>

    <!-- Previous submissions -->
    <% submissions = @step.metadata&.dig("submissions") || [] %>
    <% if submissions.any? %>
      <div class="mt-6">
        <h3 style="font-size:0.875rem; font-weight:600; color:var(--color-sub); margin:0 0 0.75rem;"><%= t('learning_engine.exercise.previous_submissions') %></h3>
        <div class="space-y-2">
          <% submissions.last(3).reverse.each do |sub| %>
            <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.5rem; padding:0.75rem; font-size:0.875rem;">
              <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.25rem;">
                <span style="color:var(--color-sub);"><%= t('learning_engine.exercise.score') %> <span style="color:<%= sub['score'].to_f >= 70 ? 'var(--color-positive)' : 'var(--color-negative)' %>;"><%= sub['score'] %>%</span></span>
                <span style="font-size:0.75rem; color:var(--color-faint-text);"><%= sub['submitted_at'] %></span>
              </div>
              <p style="color:var(--color-sub); font-size:0.75rem; margin:0;"><%= sub['feedback'] %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-12">
      <p style="color:var(--color-sub);"><%= t('learning_engine.exercise.no_content') %></p>
    </div>
  <% end %>
</div>
