<div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.75rem; padding:1rem;" data-controller="note-taking"
     data-note-taking-step-id-value="<%= @step.id %>"
     data-note-taking-save-url-value="<%= @notes.any? ? content_engine.note_path(@notes.first) : content_engine.notes_path %>">
  <h3 style="font-size:0.75rem; font-weight:600; color:var(--color-sub); text-transform:uppercase; letter-spacing:0.05em; margin:0 0 0.75rem;"><%= t('learning_engine.notes.heading') %></h3>

  <div id="notes_list">
    <% if @notes.any? %>
      <% @notes.each do |note| %>
        <div id="<%= dom_id(note) %>" style="margin-bottom:0.5rem;">
          <textarea data-action="input->note-taking#save"
                    data-note-id="<%= note.id %>"
                    style="width:100%; background:var(--color-tint-strong); border:1px solid var(--color-tint); border-radius:0.5rem; padding:0.75rem; font-size:0.875rem; color:var(--color-txt); resize:none; outline:none; font-family:inherit;"
                    rows="4" placeholder="<%= t('learning_engine.notes.placeholder') %>"><%= note.body %></textarea>
        </div>
      <% end %>
    <% else %>
      <form data-action="submit->note-taking#create" id="note_form">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <input type="hidden" name="route_step_id" value="<%= @step.id %>">
        <textarea name="body"
                  data-action="input->note-taking#save"
                  data-note-taking-target="textarea"
                  style="width:100%; background:var(--color-tint-strong); border:1px solid var(--color-tint); border-radius:0.5rem; padding:0.75rem; font-size:0.875rem; color:var(--color-txt); resize:none; outline:none; font-family:inherit;"
                  rows="4" placeholder="<%= t('learning_engine.notes.placeholder') %>"></textarea>
      </form>
    <% end %>
  </div>

  <div data-note-taking-target="savedIndicator" class="hidden" style="font-size:0.75rem; color:var(--color-faint-text); margin-top:0.25rem;"><%= t('learning_engine.notes.saved') %></div>
</div>
