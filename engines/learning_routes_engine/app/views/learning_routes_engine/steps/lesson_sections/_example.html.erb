<% section_index = defined?(index) ? index : 0 %>
<% cached_audio = ContentEngine::SectionAudioGenerator.cached(step.id, section_index) %>
<% audio_url = cached_audio&.dig(:audio_url) %>

<div style="max-width:48rem; margin:0 auto; padding:2rem 1rem;">
  <%# Badge %>
  <span class="lesson-section-badge lesson-section-badge--example">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
    <span>EJEMPLO</span>
  </span>

  <h2 style="font-size:1.5rem; font-weight:800; color:var(--color-txt); margin:0.875rem 0 1.25rem; line-height:1.3; letter-spacing:-0.3px;">
    <%= section[:title] %>
  </h2>

  <%# Content card %>
  <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-left:4px solid #10b981; border-radius:16px; padding:1.5rem 1.75rem; box-shadow:0 1px 3px rgba(16,185,129,0.04), 0 4px 16px rgba(16,185,129,0.02);">
    <div class="lesson-content" data-controller="math-renderer" data-math-renderer-target="content">
      <%= ContentEngine::MarkdownRenderer.render(section[:body]).html_safe %>
    </div>
  </div>

  <%# Action buttons %>
  <div style="margin-top:1.25rem; display:flex; flex-wrap:wrap; gap:0.5rem; align-items:center;">
    <button data-controller="ai-interaction"
            data-ai-interaction-step-id-value="<%= step.id %>"
            data-action="click->ai-interaction#request"
            data-url="<%= content_engine.give_example_lesson_path(step) %>"
            style="display:inline-flex; align-items:center; gap:0.5rem; border-radius:12px; padding:0.5rem 1.125rem; font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:600; color:#059669; background:linear-gradient(135deg, rgba(16,185,129,0.08), rgba(16,185,129,0.04)); border:1.5px solid rgba(16,185,129,0.2); cursor:pointer; transition:all 0.25s; box-shadow:0 1px 3px rgba(16,185,129,0.06);">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Dame otro ejemplo
    </button>
  </div>

  <%# Section audio mini-player %>
  <div style="margin-top:0.75rem; padding-top:0.75rem; border-top:1px solid var(--color-border-subtle);">
    <%= render "learning_routes_engine/steps/lesson_sections/section_audio_player",
               step_id: step.id,
               section_index: section_index,
               audio_url: audio_url,
               section_text: section[:body].to_s %>
  </div>
</div>
