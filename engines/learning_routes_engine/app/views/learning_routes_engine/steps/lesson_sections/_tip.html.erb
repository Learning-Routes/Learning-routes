<% section_index = defined?(index) ? index : 0 %>
<% cached_audio = ContentEngine::SectionAudioGenerator.cached(step.id, section_index) %>
<% audio_url = cached_audio&.dig(:audio_url) %>

<div style="max-width:48rem; margin:0 auto; padding:2rem 1rem;">
  <%# Badge %>
  <span class="lesson-section-badge lesson-section-badge--tip">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"/></svg>
    <span>CONSEJO</span>
  </span>

  <h2 style="font-size:1.5rem; font-weight:800; color:var(--color-txt); margin:0.875rem 0 1.25rem; line-height:1.3; letter-spacing:-0.3px;">
    <%= section[:title] %>
  </h2>

  <%# Content card with amber accent %>
  <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-left:4px solid #f59e0b; border-radius:16px; padding:1.5rem 1.75rem; box-shadow:0 1px 3px rgba(245,158,11,0.04), 0 4px 16px rgba(245,158,11,0.02);">
    <div class="lesson-content" data-controller="math-renderer" data-math-renderer-target="content">
      <%= ContentEngine::MarkdownRenderer.render(section[:body]).html_safe %>
    </div>
  </div>

  <%# Section audio mini-player %>
  <div style="margin-top:1.25rem;">
    <%= render "learning_routes_engine/steps/lesson_sections/section_audio_player",
               step_id: step.id, section_index: section_index, audio_url: audio_url,
               section_text: section[:body].to_s %>
  </div>
</div>
