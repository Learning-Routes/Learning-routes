<%# Mini audio player for concept/example sections — rendered inline or via Turbo Stream %>
<% audio_url ||= nil %>
<% duration ||= nil %>
<% step_id ||= nil %>
<% section_index ||= nil %>
<% section_text ||= "" %>

<div id="section-audio-<%= step_id %>-<%= section_index %>"
     data-controller="section-audio"
     data-section-audio-url-value="<%= audio_url %>"
     data-section-audio-step-id-value="<%= step_id %>"
     data-section-audio-section-index-value="<%= section_index %>"
     data-section-audio-section-text-value="<%= section_text %>"
     data-section-audio-generate-url-value="<%= content_engine.section_audio_generate_path(step_id: step_id, section_index: section_index) %>"
     data-section-audio-status-url-value="<%= content_engine.section_audio_status_path(step_id: step_id, section_index: section_index) %>"
     data-section-audio-mode-value="mini">

  <%# Generate button %>
  <div data-section-audio-target="generateBtn" style="<%= audio_url.present? ? 'display:none;' : '' %>">
    <button data-action="click->section-audio#generate"
            style="display:inline-flex; align-items:center; gap:0.375rem; padding:0.375rem 0.75rem; border-radius:9999px; font-size:0.75rem; font-weight:500; color:var(--color-sub); background:var(--color-tint-strong); border:1px solid var(--color-border-subtle); cursor:pointer; transition:all 0.2s;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 010 7.07"/></svg>
      Escuchar explicación
    </button>
  </div>

  <%# Player (shown when audio is ready) %>
  <div data-section-audio-target="playerWrap" style="display:<%= audio_url.present? ? '' : 'none' %>;">
    <div style="display:flex; align-items:center; gap:0.625rem;">
      <button data-action="click->section-audio#playPause"
              data-section-audio-target="playBtn"
              aria-label="Reproducir/Pausar"
              style="display:flex; align-items:center; justify-content:center; width:2rem; height:2rem; border-radius:50%; background:var(--color-accent, #2C261E); color:var(--color-accent-text, #F5F1EB); border:none; cursor:pointer; flex-shrink:0; transition:transform 0.15s;">
        <svg data-section-audio-target="playIcon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        <svg data-section-audio-target="pauseIcon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:none;"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      </button>

      <div data-section-audio-target="progressBar"
           data-action="click->section-audio#seek"
           style="flex:1; height:4px; border-radius:2px; background:var(--color-border-subtle); cursor:pointer; position:relative; overflow:hidden;">
        <div data-section-audio-target="progressFill"
             style="width:0%; height:100%; border-radius:2px; background:var(--color-accent, #2C261E); transition:width 0.1s linear;"></div>
      </div>

      <span data-section-audio-target="currentTime"
            style="font-family:'DM Mono',monospace; font-size:0.6875rem; color:var(--color-sub); min-width:2.75rem; text-align:right;">0:00</span>

      <button data-action="click->section-audio#cycleSpeed"
              data-section-audio-target="speedBtn"
              style="font-family:'DM Mono',monospace; font-size:0.625rem; font-weight:600; color:var(--color-muted); background:var(--color-tint-strong); border:1px solid var(--color-border-subtle); border-radius:9999px; padding:0.125rem 0.5rem; cursor:pointer; white-space:nowrap;">1x</button>
    </div>
  </div>

  <%# Loading state %>
  <div data-section-audio-target="loadingState" style="display:none;">
    <div style="display:flex; align-items:center; gap:0.5rem; padding:0.375rem 0;">
      <div class="section-audio-spinner"></div>
      <span style="font-size:0.75rem; color:var(--color-sub);">Generando audio...</span>
    </div>
  </div>

  <%# Error state %>
  <div data-section-audio-target="errorState" style="display:none;">
    <div style="display:flex; align-items:center; gap:0.5rem; padding:0.375rem 0;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15" stroke-linecap="round"/><line x1="9" y1="9" x2="15" y2="15" stroke-linecap="round"/></svg>
      <span style="font-size:0.75rem; color:#ef4444;">Error</span>
      <button data-action="click->section-audio#generate"
              style="font-size:0.6875rem; color:var(--color-accent); background:none; border:none; cursor:pointer; text-decoration:underline;">Reintentar</button>
    </div>
  </div>
</div>
