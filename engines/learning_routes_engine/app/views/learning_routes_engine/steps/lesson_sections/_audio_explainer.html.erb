<%# Full waveform audio player for dedicated audio sections %>
<% audio_url = section[:audio_url] %>
<% step_id = step.id %>
<% section_index = defined?(index) ? index : 0 %>
<% section_text = section[:body].to_s %>
<% cached = ContentEngine::SectionAudioGenerator.cached(step_id, section_index) %>
<% resolved_url = cached&.dig(:audio_url) || audio_url %>

<div style="max-width:48rem; margin:0 auto; padding:2rem 1rem;">
  <%# Badge %>
  <span class="lesson-section-badge lesson-section-badge--audio">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
    <span>AUDIO EXPLICACIÓN</span>
  </span>

  <h2 style="font-size:1.375rem; font-weight:700; color:var(--color-txt); margin:0.75rem 0 1.25rem; line-height:1.3;">
    <%= section[:title] %>
  </h2>

  <div id="section-audio-<%= step_id %>-<%= section_index %>"
       data-controller="section-audio"
       data-section-audio-url-value="<%= resolved_url %>"
       data-section-audio-step-id-value="<%= step_id %>"
       data-section-audio-section-index-value="<%= section_index %>"
       data-section-audio-section-text-value="<%= section_text %>"
       data-section-audio-generate-url-value="<%= content_engine.section_audio_generate_path(step_id: step_id, section_index: section_index) %>"
       data-section-audio-status-url-value="<%= content_engine.section_audio_status_path(step_id: step_id, section_index: section_index) %>"
       data-section-audio-mode-value="full"
       style="padding:1.5rem; border-radius:14px; background:var(--color-tint); border:1px solid var(--color-border-subtle);">

    <%# Generate button (shown when no audio) %>
    <div data-section-audio-target="generateBtn" style="<%= resolved_url.present? ? 'display:none;' : '' %>text-align:center; padding:1rem 0;">
      <button data-action="click->section-audio#generate"
              style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.625rem 1.25rem; border-radius:11px; font-size:0.875rem; font-weight:500; color:#6366f1; background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.2); cursor:pointer; transition:all 0.2s;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14"/></svg>
        Generar explicación en audio con IA
      </button>
    </div>

    <%# Player (shown when audio ready) %>
    <div data-section-audio-target="playerWrap" style="<%= resolved_url.present? ? '' : 'display:none;' %>">
      <%# Waveform bars — 40 bars with random heights %>
      <div style="display:flex; align-items:center; justify-content:center; gap:2px; height:3.5rem; margin-bottom:1.25rem;">
        <% bar_heights = [0.3, 0.5, 0.7, 0.4, 0.9, 0.6, 0.8, 0.35, 0.65, 0.95, 0.45, 0.75, 0.55, 0.85, 0.4, 0.7, 0.6, 0.9, 0.5, 0.8, 0.35, 0.65, 0.45, 0.95, 0.55, 0.75, 0.85, 0.4, 0.6, 0.9, 0.5, 0.7, 0.8, 0.35, 0.65, 0.45, 0.55, 0.95, 0.75, 0.85] %>
        <% bar_heights.each_with_index do |h, i| %>
          <div data-section-audio-target="waveformBar"
               class="section-audio-waveform-bar"
               style="width:3px; height:100%; border-radius:2px; background:var(--color-accent, #2C261E); opacity:0.25; transform:scaleY(<%= h %>); transition:background 0.15s, opacity 0.15s;"></div>
        <% end %>
      </div>

      <%# Play controls %>
      <div style="display:flex; align-items:center; justify-content:center; gap:1rem;">
        <button data-action="click->section-audio#playPause"
                data-section-audio-target="playBtn"
                aria-label="Reproducir/Pausar"
                style="display:flex; align-items:center; justify-content:center; width:3.5rem; height:3.5rem; border-radius:50%; background:#6366f1; color:#fff; border:none; cursor:pointer; transition:transform 0.2s;">
          <svg data-section-audio-target="playIcon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <svg data-section-audio-target="pauseIcon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="display:none;"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        </button>
      </div>

      <%# Progress bar + time %>
      <div style="display:flex; align-items:center; gap:0.5rem; margin-top:1rem;">
        <span data-section-audio-target="currentTime" style="font-family:'DM Mono',monospace; font-size:0.75rem; color:var(--color-sub); min-width:2.5rem;">0:00</span>
        <div data-section-audio-target="progressBar"
             data-action="click->section-audio#seek"
             style="flex:1; height:4px; border-radius:2px; background:var(--color-border-subtle); cursor:pointer; position:relative; overflow:hidden;">
          <div data-section-audio-target="progressFill"
               style="width:0%; height:100%; border-radius:2px; background:#6366f1; transition:width 0.1s linear;"></div>
        </div>
        <span data-section-audio-target="totalTime" style="font-family:'DM Mono',monospace; font-size:0.75rem; color:var(--color-sub); min-width:2.5rem;">--:--</span>
      </div>

      <%# Speed control %>
      <div style="display:flex; justify-content:center; margin-top:0.75rem;">
        <button data-action="click->section-audio#cycleSpeed"
                data-section-audio-target="speedBtn"
                style="font-family:'DM Mono',monospace; font-size:0.6875rem; font-weight:500; color:var(--color-muted); background:var(--color-tint-strong); border:1px solid var(--color-border-subtle); border-radius:9999px; padding:0.25rem 0.625rem; cursor:pointer;">
          1x
        </button>
      </div>
    </div>

    <%# Loading state %>
    <div data-section-audio-target="loadingState" style="display:none; text-align:center; padding:2rem 0;">
      <div class="section-audio-spinner" style="margin:0 auto 0.75rem;"></div>
      <p style="font-size:0.875rem; color:var(--color-sub); margin:0;">Generando audio con IA...</p>
      <p style="font-size:0.75rem; color:var(--color-muted); margin:0.25rem 0 0;">Esto puede tomar unos segundos</p>
    </div>

    <%# Error state %>
    <div data-section-audio-target="errorState" style="display:none; text-align:center; padding:1.5rem 0;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 0.5rem; display:block;"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      <p style="font-size:0.875rem; color:#ef4444; margin:0 0 0.5rem;">Error al generar el audio</p>
      <button data-action="click->section-audio#generate"
              style="font-size:0.8125rem; color:#6366f1; background:none; border:none; cursor:pointer; text-decoration:underline;">Reintentar</button>
    </div>
  </div>
</div>
