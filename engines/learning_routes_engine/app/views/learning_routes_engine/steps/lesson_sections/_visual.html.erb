<div style="max-width:48rem; margin:0 auto; padding:2rem 1rem;">
  <%# Badge %>
  <span class="lesson-section-badge lesson-section-badge--visual">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
    <span>VISUAL</span>
  </span>

  <h2 style="font-size:1.375rem; font-weight:700; color:var(--color-txt); margin:0.75rem 0 1rem; line-height:1.3;">
    <%= section[:title] %>
  </h2>

  <% if section[:image_url].present? %>
    <div style="margin-bottom:1.25rem; border-radius:14px; overflow:hidden; border:1px solid var(--color-border-subtle);">
      <img src="<%= section[:image_url] %>" alt="<%= section[:title] %>"
           style="width:100%; height:auto; display:block;"
           loading="lazy">
    </div>
  <% end %>

  <% if section[:body].present? %>
    <div class="lesson-content" data-controller="math-renderer" data-math-renderer-target="content">
      <%= ContentEngine::MarkdownRenderer.render(section[:body]).html_safe %>
    </div>
  <% end %>
</div>
