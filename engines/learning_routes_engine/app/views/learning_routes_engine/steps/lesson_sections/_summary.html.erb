<div style="max-width:48rem; margin:0 auto; padding:2rem 1rem;">
  <%# Badge %>
  <span class="lesson-section-badge lesson-section-badge--summary">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    <span>RESUMEN</span>
  </span>

  <h2 style="font-size:1.375rem; font-weight:700; color:var(--color-txt); margin:0.75rem 0 0.5rem; line-height:1.3;">
    Lo que aprendiste
  </h2>
  <p style="font-size:0.875rem; color:var(--color-sub); margin:0 0 1.5rem;">
    Conceptos clave de esta lección
  </p>

  <%# Key points with staggered fade-in %>
  <% if section[:key_points].present? %>
    <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.75rem;">
      <% section[:key_points].each_with_index do |point, i| %>
        <li class="lesson-summary-point animate-fade-in"
            style="display:flex; align-items:flex-start; gap:0.75rem; padding:0.875rem 1rem; border-radius:11px; background:var(--color-tint); border:1px solid var(--color-border-subtle); animation-delay:<%= i * 0.12 %>s;">
          <span style="display:flex; align-items:center; justify-content:center; width:1.5rem; height:1.5rem; border-radius:50%; background:#10b981; flex-shrink:0; margin-top:0.0625rem;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <span style="font-size:0.9375rem; font-weight:500; color:var(--color-txt); line-height:1.5;"><%= point %></span>
        </li>
      <% end %>
    </ul>
  <% end %>

  <%# Optional body text %>
  <% if section[:body].present? %>
    <div class="lesson-content" style="margin-top:1.5rem;" data-controller="math-renderer" data-math-renderer-target="content">
      <%= ContentEngine::MarkdownRenderer.render(section[:body]).html_safe %>
    </div>
  <% end %>
</div>
