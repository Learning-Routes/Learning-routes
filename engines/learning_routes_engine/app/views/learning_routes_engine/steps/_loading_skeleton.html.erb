<div class="animate-pulse space-y-4">
  <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:1.5rem;">
    <div style="width:2rem; height:2rem; background:var(--color-tint-strong); border-radius:50%;"></div>
    <div>
      <div style="height:1rem; background:var(--color-tint-strong); border-radius:0.25rem; width:12rem; margin-bottom:0.5rem;"></div>
      <div style="height:0.75rem; background:var(--color-tint); border-radius:0.25rem; width:8rem;"></div>
    </div>
  </div>

  <div style="height:1rem; background:var(--color-tint-strong); border-radius:0.25rem; width:100%;"></div>
  <div style="height:1rem; background:var(--color-tint-strong); border-radius:0.25rem; width:83%;"></div>
  <div style="height:1rem; background:var(--color-tint-strong); border-radius:0.25rem; width:66%;"></div>

  <div style="height:8rem; background:var(--color-tint); border-radius:0.75rem; margin-top:1.5rem;"></div>

  <div style="height:1rem; background:var(--color-tint-strong); border-radius:0.25rem; width:100%; margin-top:1.5rem;"></div>
  <div style="height:1rem; background:var(--color-tint-strong); border-radius:0.25rem; width:75%;"></div>
  <div style="height:1rem; background:var(--color-tint-strong); border-radius:0.25rem; width:83%;"></div>

  <div style="text-align:center; margin-top:2rem;">
    <div style="display:inline-flex; align-items:center; gap:0.5rem; font-size:0.875rem; color:var(--color-muted);">
      <svg aria-hidden="true" class="animate-spin" style="height:1rem; width:1rem;" fill="none" viewBox="0 0 24 24">
        <circle style="opacity:0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path style="opacity:0.75;" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <%= t('learning_engine.loading.generating') %>
    </div>
  </div>
</div>
