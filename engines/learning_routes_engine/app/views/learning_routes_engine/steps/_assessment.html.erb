<div class="space-y-6">
  <div>
    <span style="display:inline-flex; align-items:center; border-radius:9999px; padding:0.125rem 0.625rem; font-size:0.75rem; font-weight:500; background:var(--color-badge-assessment-bg); color:var(--color-badge-assessment-text); margin-bottom:0.5rem;">
      <%= @step.metadata&.dig('assessment_type') ? t("assessment_types.#{@step.metadata.dig('assessment_type')}", default: @step.metadata.dig('assessment_type').humanize) : t('learning_engine.assessment.badge') %>
    </span>
    <h1 style="font-size:1.5rem; font-weight:700; color:var(--color-txt); margin:0;"><%= @step.localized_title %></h1>
    <p style="font-size:0.875rem; color:var(--color-sub); margin:0.25rem 0 0;"><%= @step.localized_description %></p>
  </div>

  <% if @assessment_generating %>
    <%= render "loading_skeleton" %>
  <% elsif @assessment %>
    <% if @existing_result&.score.present? %>
      <!-- Already completed - show results summary -->
      <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.75rem; padding:1.5rem; text-align:center;">
        <div style="font-size:2.25rem; font-weight:700; margin-bottom:0.5rem; color:<%= @existing_result.passed? ? 'var(--color-positive)' : 'var(--color-negative)' %>;">
          <%= @existing_result.score.round(1) %>%
        </div>
        <p style="font-size:0.875rem; color:var(--color-sub); margin:0 0 1rem;"><%= @existing_result.passed? ? t('learning_engine.assessment.passed') : t('learning_engine.assessment.not_passed') %> (<%= t('learning_engine.assessment.passing') %> <%= @assessment.passing_score %>%)</p>
        <%= link_to t('learning_engine.assessment.view_results'), assessments.result_path(@existing_result),
            style: "display:inline-block; border-radius:0.5rem; padding:0.5rem 1rem; font-size:0.875rem; font-weight:600; color:#fff; text-decoration:none; background:linear-gradient(to right, #6366f1, #a855f7); transition:opacity 0.2s;" %>
      </div>
    <% else %>
      <!-- Start assessment -->
      <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.75rem; padding:1.5rem;">
        <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:1rem; margin-bottom:1.5rem; text-align:center;">
          <div>
            <div style="font-size:1.5rem; font-weight:700; color:var(--color-txt);"><%= @assessment.questions.count %></div>
            <div style="font-size:0.75rem; color:var(--color-muted);"><%= t('learning_engine.assessment.questions') %></div>
          </div>
          <div>
            <div style="font-size:1.5rem; font-weight:700; color:var(--color-txt);"><%= @assessment.passing_score.to_i %>%</div>
            <div style="font-size:0.75rem; color:var(--color-muted);"><%= t('learning_engine.assessment.passing_score') %></div>
          </div>
          <div>
            <div style="font-size:1.5rem; font-weight:700; color:var(--color-txt);">~<%= (@assessment.questions.count * 2).clamp(5, 60) %></div>
            <div style="font-size:0.75rem; color:var(--color-muted);"><%= t('learning_engine.assessment.minutes') %></div>
          </div>
        </div>

        <%= button_to t('learning_engine.assessment.start'), assessments.start_assessment_path(@assessment),
            method: :post,
            style: "width:100%; border-radius:0.5rem; padding:0.75rem 1rem; font-size:0.875rem; font-weight:600; color:#fff; border:none; cursor:pointer; background:linear-gradient(to right, #6366f1, #a855f7); transition:opacity 0.2s;" %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-12">
      <p style="color:var(--color-sub);"><%= t('learning_engine.assessment.not_generated') %></p>
    </div>
  <% end %>
</div>
