<div id="<%= dom_id(@step, :review) %>" class="space-y-6">
  <div>
    <span style="display:inline-flex; align-items:center; border-radius:9999px; padding:0.125rem 0.625rem; font-size:0.75rem; font-weight:500; background:var(--color-badge-review-bg); color:var(--color-badge-review-text); margin-bottom:0.5rem;">
      <%= t('learning_engine.review.badge') %>
    </span>
    <h1 style="font-size:1.5rem; font-weight:700; color:var(--color-txt); margin:0;"><%= @step.localized_title %></h1>
    <p style="font-size:0.875rem; color:var(--color-sub); margin:0.25rem 0 0;"><%= @step.localized_description %></p>
  </div>

  <!-- Memory strength indicator -->
  <% if @retrievability %>
    <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.75rem; padding:1.25rem;">
      <h3 style="font-size:0.875rem; font-weight:600; color:var(--color-sub); margin:0 0 0.75rem;"><%= t('learning_engine.review.memory_strength') %></h3>
      <div style="display:flex; align-items:center; gap:1rem;">
        <div style="flex:1;">
          <%
            strength_color = @retrievability >= 0.7 ? 'var(--color-positive)' : @retrievability >= 0.4 ? 'var(--color-warning)' : 'var(--color-negative)'
          %>
          <div style="height:0.75rem; background:var(--color-progress-track); border-radius:9999px; overflow:hidden;">
            <div style="height:100%; border-radius:9999px; transition:width 0.5s; background:<%= strength_color %>; width:<%= (@retrievability * 100).round %>%;"></div>
          </div>
        </div>
        <span style="font-size:0.875rem; font-weight:600; color:<%= strength_color %>;">
          <%= (@retrievability * 100).round %>%
        </span>
      </div>
    </div>
  <% end %>

  <!-- Concept map placeholder -->
  <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.75rem; padding:1.25rem;" data-controller="mind-map">
    <h3 style="font-size:0.875rem; font-weight:600; color:var(--color-sub); margin:0 0 0.75rem;"><%= t('learning_engine.review.concept_map') %></h3>
    <div data-mind-map-target="svg" style="width:100%; min-height:16rem; display:flex; align-items:center; justify-content:center;">
      <% if @review_steps.any? %>
        <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:0.75rem; width:100;">
          <% @review_steps.each do |step| %>
            <div style="background:var(--color-tint-strong); border:1px solid var(--color-tint); border-radius:0.5rem; padding:0.75rem; text-align:center;">
              <div style="font-size:0.75rem; font-weight:500; color:var(--color-sub); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= step.localized_title %></div>
              <div style="font-size:0.75rem; color:var(--color-muted); margin-top:0.25rem;"><%= t("learning_engine.#{step.content_type}.badge") %></div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p style="font-size:0.875rem; color:var(--color-muted);"><%= t('learning_engine.review.no_steps') %></p>
      <% end %>
    </div>
  </div>

  <!-- FSRS Rating buttons -->
  <% unless @step.completed? %>
    <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.75rem; padding:1.25rem;">
      <h3 style="font-size:0.875rem; font-weight:600; color:var(--color-sub); margin:0 0 1rem;"><%= t('learning_engine.review.prompt') %></h3>
      <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:0.75rem;">
        <%
          ratings = [
            [1, t('learning_engine.review.again'), 'var(--color-negative)', 'var(--color-negative-bg)', 'var(--color-negative-border)'],
            [2, t('learning_engine.review.hard'), 'var(--color-warning)', 'var(--color-warning-bg)', 'var(--color-warning-border)'],
            [3, t('learning_engine.review.good'), 'var(--color-positive)', 'var(--color-positive-bg)', 'var(--color-positive-border)'],
            [4, t('learning_engine.review.easy'), 'var(--color-info)', 'var(--color-info-bg)', 'var(--color-info-border)']
          ]
        %>
        <% ratings.each do |rating, label, text_color, bg_color, border_color| %>
          <%= button_to label,
              learning_routes_engine.submit_review_review_path(@step),
              params: { rating: rating },
              method: :post,
              style: "border-radius:0.5rem; padding:0.75rem; font-size:0.875rem; font-weight:600; color:#{text_color}; background:#{bg_color}; border:1px solid #{border_color}; cursor:pointer; transition:all 0.2s;" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
