<div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--color-border-subtle);" data-controller="ai-interaction"
     data-ai-interaction-step-id-value="<%= @step.id %>">
  <button data-action="click->ai-interaction#request"
          data-url="<%= content_engine.explain_differently_lesson_path(@step) %>"
          style="display:inline-flex; align-items:center; gap:0.375rem; border-radius:0.5rem; padding:0.375rem 0.75rem; font-size:0.75rem; font-weight:500; color:var(--color-sub); background:var(--color-tint-strong); border:1px solid var(--color-border-subtle); cursor:pointer; transition:all 0.2s;">
    <svg aria-hidden="true" style="width:0.875rem; height:0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
    <%= t('learning_engine.ai_buttons.explain') %>
  </button>

  <button data-action="click->ai-interaction#request"
          data-url="<%= content_engine.give_example_lesson_path(@step) %>"
          style="display:inline-flex; align-items:center; gap:0.375rem; border-radius:0.5rem; padding:0.375rem 0.75rem; font-size:0.75rem; font-weight:500; color:var(--color-sub); background:var(--color-tint-strong); border:1px solid var(--color-border-subtle); cursor:pointer; transition:all 0.2s;">
    <svg aria-hidden="true" style="width:0.875rem; height:0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
    <%= t('learning_engine.ai_buttons.example') %>
  </button>

  <button data-action="click->ai-interaction#request"
          data-url="<%= content_engine.simplify_lesson_path(@step) %>"
          style="display:inline-flex; align-items:center; gap:0.375rem; border-radius:0.5rem; padding:0.375rem 0.75rem; font-size:0.75rem; font-weight:500; color:var(--color-sub); background:var(--color-tint-strong); border:1px solid var(--color-border-subtle); cursor:pointer; transition:all 0.2s;">
    <svg aria-hidden="true" style="width:0.875rem; height:0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>
    <%= t('learning_engine.ai_buttons.simplify') %>
  </button>

  <button data-action="click->ai-interaction#request"
          data-url="<%= content_engine.deepen_lesson_path(@step) %>"
          style="display:inline-flex; align-items:center; gap:0.375rem; border-radius:0.5rem; padding:0.375rem 0.75rem; font-size:0.75rem; font-weight:500; color:var(--color-sub); background:var(--color-tint-strong); border:1px solid var(--color-border-subtle); cursor:pointer; transition:all 0.2s;">
    <svg aria-hidden="true" style="width:0.875rem; height:0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    <%= t('learning_engine.ai_buttons.deeper') %>
  </button>

  <!-- Loading indicator -->
  <div data-ai-interaction-target="loadingIndicator" class="hidden">
    <div style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.375rem 0.75rem; font-size:0.75rem; color:var(--color-sub);">
      <svg aria-hidden="true" class="animate-spin" style="height:0.875rem; width:0.875rem;" fill="none" viewBox="0 0 24 24">
        <circle style="opacity:0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path style="opacity:0.75;" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <%= t('learning_engine.ai_buttons.generating') %>
    </div>
  </div>
</div>
