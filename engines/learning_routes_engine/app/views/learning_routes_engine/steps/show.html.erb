<% content_for(:title, "#{@step.localized_title} #{t('learning_engine.route.title_suffix')}") %>

<div style="max-width:80rem; margin:0 auto; padding:2rem 1rem;">
  <div style="display:flex; gap:2rem;">
    <!-- Main content area -->
    <div style="flex:1; max-width:48rem;">
      <%= render "step_content_frame" %>

      <!-- Step social actions -->
      <div style="display:flex; align-items:center; gap:0.75rem; margin-top:1.5rem; margin-bottom:1rem;">
        <%= render "community_engine/likes/button", likeable: @step, liked: @step.liked_by?(current_user), likes_count: @step.likes.count %>
      </div>

      <!-- Navigation -->
      <%= render "navigation" %>

      <!-- Comments section -->
      <div style="margin-top:2.5rem; padding-top:2rem; border-top:1px solid var(--color-border-subtle);">
        <%= render "community_engine/comments/section", commentable: @step %>
      </div>
    </div>

    <!-- Sidebar -->
    <%= render "sidebar" %>
  </div>
</div>
