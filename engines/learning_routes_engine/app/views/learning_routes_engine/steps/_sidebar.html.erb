<aside class="hidden xl:block" style="width:18rem; flex-shrink:0;">
  <div class="sticky top-20 space-y-4">
    <!-- Step info card -->
    <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.75rem; padding:1rem;">
      <h3 style="font-size:0.75rem; font-weight:600; color:var(--color-sub); text-transform:uppercase; letter-spacing:0.05em; margin:0 0 0.75rem;"><%= t('learning_engine.sidebar.step_info') %></h3>
      <div class="space-y-2" style="font-size:0.875rem;">
        <div style="display:flex; justify-content:space-between;">
          <span style="color:var(--color-muted);"><%= t('learning_engine.sidebar.type') %></span>
          <span style="color:var(--color-sub);"><%= @step.content_type ? t("content_types.#{@step.content_type}", default: @step.content_type.capitalize) : "\u2014" %></span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span style="color:var(--color-muted);"><%= t('learning_engine.sidebar.level') %></span>
          <span style="color:var(--color-sub);"><%= @step.level ? t("content_levels.#{@step.level}", default: @step.level.upcase) : "\u2014" %></span>
        </div>
        <% if @step.estimated_minutes.to_i > 0 %>
          <div style="display:flex; justify-content:space-between;">
            <span style="color:var(--color-muted);"><%= t('learning_engine.sidebar.duration') %></span>
            <span style="color:var(--color-sub);"><%= t('learning_engine.route.duration', minutes: @step.estimated_minutes) %></span>
          </div>
        <% end %>
        <% if @step.bloom_level.to_i > 0 %>
          <div style="display:flex; justify-content:space-between;">
            <span style="color:var(--color-muted);"><%= t('learning_engine.sidebar.blooms') %></span>
            <span style="color:var(--color-sub);"><%= Assessments::Question::BLOOM_LEVELS[@step.bloom_level.to_i] rescue t("units.level", n: @step.bloom_level) %></span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Notes -->
    <%= render "notes" %>

    <!-- Progress overview -->
    <div style="background:var(--color-card); border:1px solid var(--color-border-subtle); border-radius:0.75rem; padding:1rem;">
      <h3 style="font-size:0.75rem; font-weight:600; color:var(--color-sub); text-transform:uppercase; letter-spacing:0.05em; margin:0 0 0.75rem;"><%= t('learning_engine.sidebar.progress') %></h3>
      <div style="text-align:center;">
        <div style="font-size:1.5rem; font-weight:700; color:var(--color-txt);"><%= @progress[:percentage] %>%</div>
        <div style="font-size:0.75rem; color:var(--color-muted); margin-top:0.25rem;"><%= @progress[:completed_steps] %>/<%= @progress[:total_steps] %> <%= t('learning_engine.sidebar.steps') %></div>
      </div>
      <div style="height:0.375rem; background:var(--color-progress-track); border-radius:9999px; overflow:hidden; margin-top:0.75rem;" role="progressbar" aria-valuenow="<%= @progress[:percentage] %>" aria-valuemin="0" aria-valuemax="100" aria-label="<%= t('learning_engine.progress.aria', percent: @progress[:percentage]) %>">
        <div style="height:100%; background:linear-gradient(to right, #6366f1, #a855f7); border-radius:9999px; width:<%= @progress[:percentage] %>%;" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</aside>
