<% if @content_generating %>
  <%= render "loading_skeleton" %>
<% elsif @sections.present? %>
  <% engagement = current_user&.user_engagement %>
  <% quiz_count = @sections.count { |s| s[:type] == "check" } %>

  <%# ── Floating particles background ── %>
  <div class="lesson-particles" data-controller="lesson-particles" data-lesson-particles-target="container" aria-hidden="true"></div>

  <%# ── Duolingo-style section navigation ── %>
  <div data-controller="interactive-lesson"
       data-interactive-lesson-total-sections-value="<%= @sections.size %>"
       data-interactive-lesson-step-id-value="<%= @step.id %>"
       data-interactive-lesson-route-id-value="<%= @route.id %>"
       data-interactive-lesson-complete-url-value="<%= complete_route_step_path(@route, @step) %>"
       data-interactive-lesson-hearts-value="<%= quiz_count.clamp(3, 5) %>"
       data-interactive-lesson-user-level-value="<%= engagement&.current_level || 1 %>"
       data-interactive-lesson-user-xp-pct-value="<%= engagement&.level_progress_percentage || 0 %>"
       data-interactive-lesson-user-streak-value="<%= engagement&.current_streak || 0 %>">

    <%# ── Sticky HUD: progress + hearts + streak + XP bar ── %>
    <div class="lesson-hud">
      <%# Progress bar %>
      <div class="lesson-hud-progress" data-interactive-lesson-target="progressBar">
        <% @sections.each_with_index do |_sec, i| %>
          <div class="lesson-progress-segment" data-interactive-lesson-target="progressSegment"></div>
        <% end %>
      </div>

      <%# Stats row %>
      <div class="lesson-hud-stats">
        <%# Section counter %>
        <span class="lesson-progress-counter" data-interactive-lesson-target="sectionCounter">1/<%= @sections.size %></span>

        <div style="flex:1;"></div>

        <%# Hearts %>
        <% if quiz_count > 0 %>
          <div class="lesson-hud-hearts" data-interactive-lesson-target="heartsWrap">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="#EF4444"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"/></svg>
            <span data-interactive-lesson-target="heartsCount"><%= quiz_count.clamp(3, 5) %></span>
          </div>
        <% end %>

        <%# Streak %>
        <% if engagement&.current_streak.to_i > 0 %>
          <div class="lesson-hud-streak">
            <span class="lesson-hud-streak-fire">🔥</span>
            <span><%= engagement.current_streak %></span>
          </div>
        <% end %>

        <%# XP bar %>
        <div class="lesson-hud-xp" data-interactive-lesson-target="xpBarWrap">
          <div class="lesson-hud-xp-track">
            <div class="lesson-hud-xp-fill" data-interactive-lesson-target="xpFill"
                 style="width:<%= engagement&.level_progress_percentage || 0 %>%;"></div>
          </div>
          <div class="lesson-hud-xp-level" data-interactive-lesson-target="xpLevel">
            <%= engagement&.current_level || 1 %>
          </div>
        </div>
      </div>
    </div>

    <%# ── Step title ── %>
    <div style="max-width:48rem; margin:0 auto; padding:0.5rem 1rem 0;">
      <h1 style="font-size:1.5rem; font-weight:700; color:var(--color-txt); margin:0;"><%= @step.localized_title %></h1>
      <p style="font-size:0.875rem; color:var(--color-sub); margin:0.25rem 0 0;"><%= @step.localized_description %></p>
    </div>

    <%# ── Sections container (only one visible at a time) ── %>
    <div class="lesson-sections-container" data-interactive-lesson-target="sectionsContainer">
      <% @sections.each_with_index do |section, i| %>
        <div class="lesson-section"
             data-interactive-lesson-target="section"
             data-section-type="<%= section[:type] %>"
             <% if section[:type] == "check" %>
               data-lesson-check="true"
             <% end %>
             style="<%= i > 0 ? 'display:none;' : '' %>">
          <% section_type = %w[concept example check visual summary audio audio_explainer tip].include?(section[:type].to_s) ? section[:type] : "concept" %>
          <%= render "learning_routes_engine/steps/lesson_sections/#{section_type}", section: section, step: @step, index: i %>
        </div>
      <% end %>
    </div>

    <%# ── Companion (floating helper — not an owl!) ── %>
    <div class="lesson-companion" data-interactive-lesson-target="companion" data-action="click->interactive-lesson#companionTap">
      <div class="lesson-companion-body">🚀</div>
      <div class="lesson-companion-bubble" data-interactive-lesson-target="companionBubble"></div>
    </div>

    <%# ── Fixed continue button ── %>
    <div class="lesson-nav-footer" data-interactive-lesson-target="continueBar">
      <div style="max-width:48rem; margin:0 auto; display:flex; gap:0.75rem;">
        <button data-action="click->interactive-lesson#previousSection"
                data-interactive-lesson-target="backBtn"
                class="lesson-btn--back"
                style="display:none;"
                aria-label="Anterior">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button data-interactive-lesson-target="continueBtn"
                data-action="click->interactive-lesson#nextSection"
                class="lesson-btn--primary"
                style="flex:1;">
          <span data-interactive-lesson-target="continueBtnText">Continuar</span>
        </button>
      </div>
    </div>

    <%# ── Level up overlay ── %>
    <div class="lesson-lvlup-overlay" data-interactive-lesson-target="levelUpOverlay" style="display:none;">
      <div class="lesson-lvlup-ring">
        <div class="lesson-lvlup-inner">
          <span class="lesson-lvlup-num" data-interactive-lesson-target="levelUpNum"></span>
          <span class="lesson-lvlup-label mono">NIVEL</span>
        </div>
      </div>
      <h3 class="lesson-lvlup-title">¡Subiste de nivel!</h3>
      <p class="lesson-lvlup-sub">Sigue así, vas increíble</p>
    </div>

    <%# ── XP toast ── %>
    <div class="lesson-toast" data-interactive-lesson-target="toast" aria-live="polite"></div>

    <%# ── AI interaction buttons (collapsed at bottom) ── %>
    <div style="max-width:48rem; margin:0 auto; padding:0 1rem;">
      <%= render "ai_buttons" %>
      <div id="ai_supplementary_<%= @step.id %>" class="space-y-4"></div>
    </div>
  </div>
<% elsif @content %>
  <%# ── Fallback: monolithic render if parser returned no sections ── %>
  <div class="space-y-6">
    <div>
      <span style="display:inline-flex; align-items:center; border-radius:9999px; padding:0.125rem 0.625rem; font-size:0.75rem; font-weight:500; background:var(--color-badge-lesson-bg); color:var(--color-badge-lesson-text); margin-bottom:0.5rem;">
        <%= t('learning_engine.lesson.badge') %>
      </span>
      <h1 style="font-size:1.5rem; font-weight:700; color:var(--color-txt); margin:0;"><%= @step.localized_title %></h1>
    </div>
    <div class="lesson-content" data-controller="math-renderer" data-math-renderer-target="content">
      <%= @rendered_html %>
    </div>
    <%= render "ai_buttons" %>
    <div id="ai_supplementary_<%= @step.id %>" class="space-y-4"></div>
  </div>
<% else %>
  <div class="text-center py-12">
    <p style="color:var(--color-sub);"><%= t('learning_engine.lesson.no_content') %></p>
  </div>
<% end %>
