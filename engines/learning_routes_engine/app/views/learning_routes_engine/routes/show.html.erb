<% content_for(:title, "#{@route.localized_topic} #{t('learning_engine.route.title_suffix')}") %>

<div style="max-width:56rem; margin:0 auto; padding:2.5rem 1.5rem;">
  <!-- Route header -->
  <div style="margin-bottom:2rem;">
    <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.5rem;">
      <%= link_to main_app.dashboard_path, style: "color:var(--color-sub); text-decoration:none; transition:color 0.2s;", aria: { label: t('layout.learning.dashboard') } do %>
        <svg aria-hidden="true" style="width:1.25rem; height:1.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>
      <h1 style="font-size:1.5rem; font-weight:700; color:var(--color-txt); margin:0;"><%= @route.localized_topic %></h1>
    </div>

    <!-- Progress -->
    <div style="margin-top:1rem;">
      <%= render "learning_routes_engine/routes/progress", route: @route, summary: @progress %>
    </div>
  </div>

  <!-- Social actions -->
  <div style="display:flex; align-items:center; gap:0.75rem; margin-top:1rem; margin-bottom:1.5rem;">
    <%= render "community_engine/likes/button", likeable: @route, liked: @route.liked_by?(current_user), likes_count: @route.likes.count %>
  </div>

  <!-- Due reviews -->
  <% if @due_reviews.any? %>
    <div style="margin-bottom:2rem; background:var(--color-due-bg); border:1px solid var(--color-due-border); border-radius:0.75rem; padding:1.25rem;">
      <h3 style="font-size:0.875rem; font-weight:600; color:var(--color-due-heading); margin:0 0 0.75rem;"><%= t('learning_engine.route.reviews_due', count: @due_reviews.size) %></h3>
      <div style="display:flex; flex-direction:column; gap:0.5rem;">
        <% @due_reviews.first(3).each do |step| %>
          <%= link_to route_step_path(@route, step), style: "font-size:0.875rem; color:var(--color-due-text); text-decoration:none; transition:color 0.2s;" do %>
            <%= step.localized_title %>
          <% end %>
        <% end %>
      </div>
      <% if @due_reviews.size > 3 %>
        <%= link_to t('learning_engine.route.see_all_reviews'), reviews_path, style: "font-size:0.75rem; color:var(--color-due-link); text-decoration:none; margin-top:0.5rem; display:inline-block;" %>
      <% end %>
    </div>
  <% end %>

  <!-- Steps list -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem;">
    <h2 style="font-size:0.875rem; font-weight:600; color:var(--color-sub); text-transform:uppercase; letter-spacing:0.05em; margin:0;"><%= t('learning_engine.route.steps_title', default: 'Steps') %></h2>
    <%= link_to main_app.profile_path, style: "display:inline-flex; align-items:center; gap:0.375rem; font-size:0.75rem; font-weight:500; color:var(--color-muted); text-decoration:none; background:var(--color-tint); border:1px solid var(--color-border-subtle); border-radius:0.5rem; padding:0.375rem 0.75rem; transition:all 0.2s;" do %>
      <svg aria-hidden="true" style="width:0.875rem; height:0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      <%= t('learning_engine.route.exit_route', default: 'Exit Route') %>
    <% end %>
  </div>

  <div style="display:flex; flex-direction:column; gap:0.75rem;">
    <% @steps.each_with_index do |step, index| %>
      <% accessible = step.completed? || step.in_progress? || step.available? %>
      <div style="position:relative; background:var(--color-card); border-radius:0.75rem; border:1px solid var(--color-border-subtle); padding:1rem; transition:all 0.2s; <%= 'cursor:pointer;' if accessible %> <%= 'opacity:0.5;' if step.locked? %>">
        <% if accessible %>
          <%= link_to route_step_path(@route, step), style: "position:absolute; inset:0; z-index:10;", aria: { label: step.localized_title }, tabindex: "-1" do %><% end %>
        <% end %>

        <div style="display:flex; align-items:center; gap:1rem;">
          <!-- Status icon -->
          <%
            icon_bg = step.completed? ? 'var(--color-step-completed-bg)' :
                      step.in_progress? ? 'var(--color-step-progress-bg)' :
                      step.available? ? 'var(--color-step-available-bg)' :
                      'var(--color-step-locked-bg)'
            icon_color = step.completed? ? 'var(--color-step-completed-icon)' :
                         step.in_progress? ? 'var(--color-step-progress-icon)' :
                         step.available? ? 'var(--color-txt)' :
                         'var(--color-step-locked-icon)'
          %>
          <div style="flex-shrink:0; width:2.5rem; height:2.5rem; border-radius:50%; display:flex; align-items:center; justify-content:center; background:<%= icon_bg %>; color:<%= icon_color %>;">
            <% if step.completed? %>
              <svg aria-hidden="true" style="width:1.25rem; height:1.25rem;" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <% elsif step.locked? %>
              <svg aria-hidden="true" style="width:1.25rem; height:1.25rem;" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
            <% else %>
              <span style="font-size:0.875rem; font-weight:700;"><%= index + 1 %></span>
            <% end %>
          </div>

          <!-- Step info -->
          <div style="flex:1; min-width:0;">
            <div style="display:flex; align-items:center; gap:0.5rem;">
              <h3 style="font-size:0.875rem; font-weight:600; color:var(--color-txt); margin:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= step.localized_title %></h3>
              <%
                badge_bg = case step.content_type
                           when 'lesson' then 'var(--color-badge-lesson-bg)'
                           when 'exercise' then 'var(--color-badge-exercise-bg)'
                           when 'assessment' then 'var(--color-badge-assessment-bg)'
                           when 'review' then 'var(--color-badge-review-bg)'
                           else 'var(--color-tint-strong)'
                           end
                badge_color = case step.content_type
                              when 'lesson' then 'var(--color-badge-lesson-text)'
                              when 'exercise' then 'var(--color-badge-exercise-text)'
                              when 'assessment' then 'var(--color-badge-assessment-text)'
                              when 'review' then 'var(--color-badge-review-text)'
                              else 'var(--color-sub)'
                              end
              %>
              <span style="display:inline-flex; align-items:center; border-radius:9999px; padding:0.125rem 0.5rem; font-size:0.75rem; font-weight:500; background:<%= badge_bg %>; color:<%= badge_color %>;">
                <%= t("learning_engine.#{step.content_type}.badge") %>
              </span>
            </div>
            <p style="font-size:0.75rem; color:var(--color-muted); margin:0.125rem 0 0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= step.localized_description %></p>
          </div>

          <!-- Duration -->
          <div style="flex-shrink:0; font-size:0.75rem; color:var(--color-muted);">
            <% if step.estimated_minutes.to_i > 0 %>
              <%= t('learning_engine.route.duration', minutes: step.estimated_minutes) %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Comments section -->
  <div style="margin-top:2.5rem; padding-top:2rem; border-top:1px solid var(--color-border-subtle);">
    <%= render "community_engine/comments/section", commentable: @route %>
  </div>
</div>
