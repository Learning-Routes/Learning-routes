<h1 style="font-size: 22px; font-weight: 700; color: #1C1812; margin: 0 0 16px;"><%= t("mailer.route_deletion.heading") %></h1>

<p style="font-size: 15px; line-height: 1.6; color: #1C1812; margin: 0 0 8px;"><%= t("mailer.route_deletion.greeting", name: @user.name) %></p>

<p style="font-size: 15px; line-height: 1.6; color: #1C1812; margin: 0 0 24px;"><%= t("mailer.route_deletion.body", route: @route.localized_topic) %></p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 24px;">
  <tr>
    <td style="background-color: #2C261E; border-radius: 8px; padding: 16px 32px; text-align: center;">
      <span style="font-family: 'DM Mono', monospace; font-size: 28px; font-weight: 700; color: #F5F1EB; letter-spacing: 0.3em;"><%= @code %></span>
    </td>
  </tr>
</table>

<p style="font-size: 13px; line-height: 1.5; color: #6D665B; margin: 0 0 8px;"><%= t("mailer.route_deletion.expiry") %></p>

<p style="font-size: 13px; line-height: 1.5; color: #A09889; margin: 0;"><%= t("mailer.route_deletion.ignore") %></p>
