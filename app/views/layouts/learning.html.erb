<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-controller="theme" data-theme-preference-value="<%= current_theme %>">
  <head>
    <title><%= content_for(:title) || t("layout.app_name") %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#F5F1EB">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg?v=2" type="image/svg+xml">
    <link rel="icon" href="/icon.png?v=2" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css">

    <%# Prevent flash of wrong theme before JS loads %>
    <script>
      (function(){
        var p = "<%= current_theme %>";
        var t = p === "system" ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light") : p;
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>

    <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="margin:0; min-height:100vh; font-family:'DM Sans',sans-serif; background:var(--color-bg); color:var(--color-txt); transition:background-color 0.3s, color 0.3s;">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-4 focus:z-[200] focus:bg-indigo-500 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold"><%= t("layout.skip_to_content") %></a>
    <%= turbo_stream_from "learning_route_#{@route.id}" if @route %>
    <%= turbo_stream_from "step_content_#{@step.id}" if @step %>

    <!-- Top navigation bar -->
    <nav class="learning-nav" style="position:sticky; top:0; z-index:50;">
      <div style="max-width:80rem; margin:0 auto; padding:0 1rem;">
        <div style="display:flex; height:3.5rem; align-items:center; justify-content:space-between;">
          <div style="display:flex; align-items:center; gap:1rem;">
            <% if @step && @route %>
              <%# When viewing a step, back goes to the route (not dashboard) %>
              <%= link_to learning_routes_engine.route_path(@route), style: "font-size:0.875rem; font-weight:500; color:var(--color-sub); text-decoration:none; display:inline-flex; align-items:center; transition:color 0.2s;" do %>
                <svg aria-hidden="true" style="width:1.25rem; height:1.25rem; margin-right:0.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                <%= @route.localized_topic.truncate(25) %>
              <% end %>
            <% else %>
              <%# When viewing a route overview, back goes to dashboard %>
              <%= link_to main_app.dashboard_path, style: "font-size:0.875rem; font-weight:500; color:var(--color-sub); text-decoration:none; display:inline-flex; align-items:center; transition:color 0.2s;" do %>
                <svg aria-hidden="true" style="width:1.25rem; height:1.25rem; margin-right:0.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                <%= t("layout.learning.dashboard") %>
              <% end %>

              <% if @route %>
                <span style="color:var(--color-faint);">|</span>
                <span style="font-size:0.875rem; font-weight:600; color:var(--color-txt); max-width:20rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= @route.localized_topic %></span>
              <% end %>
            <% end %>
          </div>

          <div style="display:flex; align-items:center; gap:1rem;">
            <% if @step && @progress %>
              <span style="font-size:0.75rem; color:var(--color-sub);">
                <%= t("layout.learning.step_of", current: @step.position + 1, total: @progress[:total_steps]) %>
              </span>
            <% end %>

            <div style="display:flex; align-items:center; gap:0.5rem;" data-controller="lesson"
                 data-lesson-step-id-value="<%= @step&.id %>"
                 data-lesson-route-id-value="<%= @route&.id %>">
              <span style="font-size:0.75rem; font-family:'DM Mono',monospace; color:var(--color-muted);" data-lesson-target="timer">0:00</span>

              <% if @step && !@step.completed? %>
                <div id="step_complete_btn">
                  <%= button_to t("layout.learning.complete_step"),
                      learning_routes_engine.complete_route_step_path(@route, @step),
                      method: :post,
                      style: "border-radius:0.5rem; padding:0.375rem 1rem; font-size:0.75rem; font-weight:600; color:#fff; border:none; cursor:pointer; background:linear-gradient(to right, #6366f1, #a855f7); transition:opacity 0.2s;",
                      data: { lesson_target: "markCompleteBtn" } %>
                </div>
              <% end %>
            </div>

            <% if current_user %>
              <span style="font-size:0.75rem; color:var(--color-muted);"><%= current_user.name %></span>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Progress bar -->
      <% if @progress %>
        <div style="height:4px; background:var(--color-progress-track);" role="progressbar" aria-valuenow="<%= @progress[:percentage] %>" aria-valuemin="0" aria-valuemax="100" aria-label="<%= t("layout.learning.progress_aria", percent: @progress[:percentage]) %>">
          <div style="height:100%; background:linear-gradient(to right, #6366f1, #a855f7); transition:width 0.5s; width:<%= @progress[:percentage] %>%;"
               id="route_progress_bar"></div>
        </div>
      <% end %>
    </nav>

    <!-- Flash messages -->
    <% if flash[:notice] || flash[:alert] %>
      <div style="max-width:80rem; margin:1rem auto 0; padding:0 1rem;">
        <% if flash[:notice] %>
          <div style="border-radius:0.625rem; background:var(--color-flash-notice-bg); border:1px solid var(--color-flash-notice-border); padding:0.75rem 1rem; font-size:0.875rem; color:var(--color-flash-notice-text);"
               data-controller="flash">
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <p style="margin:0;"><%= flash[:notice] %></p>
              <button data-action="click->flash#dismiss" style="background:none; border:none; color:var(--color-flash-notice-text); cursor:pointer; margin-left:1rem; padding:4px;" aria-label="<%= t('layout.dismiss') %>">
                <svg style="height:1rem; width:1rem;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/></svg>
              </button>
            </div>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div style="border-radius:0.625rem; background:var(--color-flash-alert-bg); border:1px solid var(--color-flash-alert-border); padding:0.75rem 1rem; font-size:0.875rem; color:var(--color-flash-alert-text);"
               data-controller="flash">
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <p style="margin:0;"><%= flash[:alert] %></p>
              <button data-action="click->flash#dismiss" style="background:none; border:none; color:var(--color-flash-alert-text); cursor:pointer; margin-left:1rem; padding:4px;" aria-label="<%= t('layout.dismiss') %>">
                <svg style="height:1rem; width:1rem;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/></svg>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Main content -->
    <main id="main-content">
      <%= yield %>
    </main>

    <%# === Celebration container (Turbo Stream target) === %>
    <div id="celebrations" style="position:fixed; inset:0; pointer-events:none; z-index:9998;"></div>
  </body>
</html>
