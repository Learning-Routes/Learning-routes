<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-controller="theme" data-theme-preference-value="<%= current_theme %>">
  <head>
    <title><%= content_for(:title) || t("layout.app_name") %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#F5F1EB">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg?v=2" type="image/svg+xml">
    <link rel="icon" href="/icon.png?v=2" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <%# Prevent flash of wrong theme before JS loads %>
    <script nonce="<%= content_security_policy_nonce %>">
      (function(){
        var p = "<%= current_theme %>";
        var t = p === "system" ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light") : p;
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>

    <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="height:100%; margin:0; background:var(--color-bg); color:var(--color-txt); font-family:'Manrope',sans-serif; overflow:hidden; transition:background-color 0.3s, color 0.3s;">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-4 focus:z-[200] focus:bg-indigo-500 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold"><%= t("layout.skip_to_content") %></a>

    <%# Fixed top bar %>
    <nav id="journey-topbar" style="position:fixed; top:0; left:0; right:0; z-index:30; padding:14px 28px; background:linear-gradient(var(--color-bg) 50%, transparent); backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px); display:flex; justify-content:space-between; align-items:center;">
      <%= link_to main_app.profile_path, style: "font-family:'Manrope',sans-serif; font-size:0.72rem; color:var(--color-muted); text-decoration:none; transition:color 0.2s;", "aria-label": t("learning_engine.journey.back_to_profile") do %>
        &larr; <%= t("learning_engine.journey.back_to_profile") %>
      <% end %>

      <div style="font-family:'Instrument Serif',serif; font-size:0.92rem; font-style:italic; color:var(--color-txt);">
        <%= @route.localized_topic %>
      </div>

      <div style="display:flex; align-items:center; gap:12px;">
        <% if @due_reviews&.any? %>
          <%= link_to learning_routes_engine.reviews_path, style: "display:inline-flex; align-items:center; gap:4px; font-family:'JetBrains Mono',monospace; font-size:0.55rem; color:var(--color-due-heading); text-decoration:none; background:var(--color-due-bg); padding:3px 8px; border-radius:6px;" do %>
            <svg width="10" height="10" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 4v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <%= @due_reviews.size %>
          <% end %>
        <% end %>
        <% if @progress %>
          <span style="font-family:'JetBrains Mono',monospace; font-size:0.55rem; color:var(--color-muted);">
            <%= @progress[:completed_steps] %>/<%= @progress[:total_steps] %>
          </span>
        <% end %>
      </div>
    </nav>

    <%# Flash messages %>
    <% if flash[:notice] || flash[:alert] %>
      <div style="position:fixed; top:52px; left:50%; transform:translateX(-50%); z-index:40; max-width:500px; width:90%;">
        <% if flash[:notice] %>
          <div role="status" style="background:var(--color-flash-notice-bg); border:1px solid var(--color-flash-notice-border); border-radius:10px; padding:10px 16px; font-size:0.82rem; color:var(--color-flash-notice-text); margin-bottom:8px;" data-controller="flash">
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <p style="margin:0;"><%= flash[:notice] %></p>
              <button data-action="click->flash#dismiss" aria-label="<%= t('layout.dismiss', default: 'Dismiss') %>" style="background:none; border:none; color:var(--color-flash-notice-text); cursor:pointer; padding:4px;">
                <svg style="width:14px; height:14px;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/></svg>
              </button>
            </div>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div role="alert" style="background:var(--color-flash-alert-bg); border:1px solid var(--color-flash-alert-border); border-radius:10px; padding:10px 16px; font-size:0.82rem; color:var(--color-flash-alert-text);" data-controller="flash">
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <p style="margin:0;"><%= flash[:alert] %></p>
              <button data-action="click->flash#dismiss" aria-label="<%= t('layout.dismiss', default: 'Dismiss') %>" style="background:none; border:none; color:var(--color-flash-alert-text); cursor:pointer; padding:4px;">
                <svg style="width:14px; height:14px;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/></svg>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Main content %>
    <main id="main-content" style="height:100%;">
      <%= yield %>
    </main>

    <%# Bottom gradient fade %>
    <div style="position:fixed; bottom:0; left:0; right:0; height:50px; z-index:10; background:linear-gradient(transparent, var(--color-bg)); pointer-events:none;"></div>
  </body>
</html>
