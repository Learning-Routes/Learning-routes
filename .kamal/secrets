# Secrets for Kamal deployment
# Values extracted from .env using dotenv-compatible command substitution

# Docker Hub
KAMAL_REGISTRY_USERNAME=$(grep '^KAMAL_REGISTRY_USERNAME=' .env | cut -d= -f2-)
KAMAL_REGISTRY_PASSWORD=$(grep '^KAMAL_REGISTRY_PASSWORD=' .env | cut -d= -f2-)

# Rails master key
RAILS_MASTER_KEY=$(cat config/master.key 2>/dev/null)

# Self-hosted Postgres (production) — runs as a Kamal accessory on the app box.
# Production database.yml uses explicit host/port/user/password/database fields
# (not a URL) — the underscore in the Kamal accessory hostname (`learning_routes-postgres`)
# trips Ruby's URI registry-vs-server-authority discrimination in db:prepare.
# So we only ship POSTGRES_PASSWORD here; the rest is hardcoded in database.yml.
POSTGRES_PASSWORD=$(grep '^POSTGRES_PASSWORD=' .env | cut -d= -f2-)

# App third-party secrets (OpenAI, ElevenLabs, Tavily, Brevo SMTP, Google OAuth)
# are NO LONGER shipped as ENV. They live in encrypted Rails credentials and are
# decrypted at runtime via RAILS_MASTER_KEY above. Nothing to add here for them.
